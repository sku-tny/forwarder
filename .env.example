# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
ALLOWED_USER_IDS=your_telegram_user_id_here   # comma-separated if multiple
EMAIL_RECIPIENT_ID=your_telegram_user_id_here  # who receives the codes

# ── iCloud IMAP ───────────────────────────────────────────────────────────────
# Leave IMAP_USER / IMAP_PASS empty to disable monitoring.
#
# IMAP_PASS must be an App-Specific Password — NOT your Apple ID password.
# Generate one at: appleid.apple.com → Sign-In & Security → App-Specific Passwords
IMAP_HOST=imap.mail.me.com
IMAP_PORT=993
IMAP_USER=yourname@icloud.com
IMAP_PASS=xxxx-xxxx-xxxx-xxxx

# ── Optional ──────────────────────────────────────────────────────────────────
EMAIL_POLL_INTERVAL=30   # seconds between inbox checks (default: 30)
